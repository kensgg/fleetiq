# Dependencies (already in image via npm ci)
node_modules
npm-debug.log*

# Next.js build output (built inside Docker)
.next
out

# Git
.git
.gitignore

# Env files (injected at runtime via env_file / ARG)
.env*

# SSL certificates (never bake into image)
nginx/certs

# Editor / OS artifacts
.DS_Store
*.pem
.vscode
.idea

# Misc
README.md
CLAUDE.md
AGENTS.md
*.tsbuildinfo
